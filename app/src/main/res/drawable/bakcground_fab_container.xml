<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/background_fab_container.xml -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Bayangan (Shadow) -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <solid android:color="#20000000" /> <!-- Bayangan lembut -->
            <padding
                android:bottom="2dp"
                android:right="2dp"
                android:left="2dp"
                android:top="2dp" />
        </shape>
    </item>

    <!-- Background Utama -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <solid android:color="@color/white" />
            <stroke
                android:width="1dp"
                android:color="#DDDDDD" />
        </shape>
    </item>
</layer-list>