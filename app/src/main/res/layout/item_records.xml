<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/background_cart"
    android:padding="10dp"
    android:layout_marginTop="10dp"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    android:id="@+id/item_layout">

    <ImageView
        android:id="@+id/imgItemPesanan"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginEnd="200dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:srcCompat="@tools:sample/avatars" />

    <TextView
        android:id="@+id/txt_pesanan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:text="Pesanan"
        android:textSize="14sp"
        android:textColor="@color/black"
        app:layout_constraintStart_toEndOf="@+id/imgItemPesanan"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txt_harga"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginStart="10dp"
        android:text="300.000"
        android:textColor="@color/brown"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@+id/imgItemPesanan"
        app:layout_constraintTop_toBottomOf="@+id/txt_pesanan" />

    <TextView
        android:id="@+id/txt_jml_pesanan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginTop="10dp"
        android:text="Jumlah Pesanan"
        android:textColor="@color/black"
        app:layout_constraintStart_toEndOf="@+id/imgItemPesanan"
        app:layout_constraintTop_toBottomOf="@+id/txt_harga" />

    <Button
        android:id="@+id/btn_kurang"
        android:layout_width="50dp"
        android:layout_height="25dp"
        android:layout_marginTop="15dp"
        android:layout_marginStart="10dp"
        android:background="@drawable/btn_bg_design"
        android:text="-"
        android:textColor="@color/white"
        app:layout_constraintStart_toEndOf="@+id/imgItemPesanan"
        app:layout_constraintTop_toBottomOf="@+id/txt_jml_pesanan" />

    <Button
        android:id="@+id/btn_tambah"
        android:layout_width="50dp"
        android:layout_height="25dp"
        android:layout_marginTop="15dp"
        android:layout_marginStart="10dp"
        android:background="@drawable/btn_bg_design"
        android:text="+"
        android:textColor="@color/white"
        app:layout_constraintStart_toEndOf="@+id/btn_kurang"
        app:layout_constraintTop_toBottomOf="@+id/txt_jml_pesanan" />

    <Button
        android:id="@+id/btn_hapus"
        android:layout_width="50dp"
        android:layout_height="25dp"
        android:layout_marginTop="15dp"
        android:layout_marginStart="10dp"
        android:background="@drawable/btn_bg_design"
        android:text="Hapus"
        android:textColor="@color/white"
        android:textSize="10sp"
        app:layout_constraintStart_toEndOf="@+id/btn_tambah"
        app:layout_constraintTop_toBottomOf="@+id/txt_jml_pesanan" />

</androidx.constraintlayout.widget.ConstraintLayout>
