<!-- res/layout/activity_checkout.xml -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_detail_pesanan"
    tools:context=".CheckoutActivity">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Kembali"
            android:layout_marginStart="8dp"
            android:layout_gravity="start|center_vertical" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Checkout"
            android:textColor="@color/brown"
            android:textSize="24sp"
            android:fontFamily="@font/biryani_extrabold"
            android:layout_gravity="center"
            android:layout_marginStart="16dp" />
    </androidx.appcompat.widget.Toolbar>

    <!-- NestedScrollView -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/toolbar"
        app:layout_constraintBottom_toTopOf="@+id/total_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Catatan -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/background_checkout"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Catatan!"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:fontFamily="@font/biryani_bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Kami hanya melayani pengiriman di seluruh wilayah Kota dan Kabupaten Bekasi"
                    android:textColor="@color/black"
                    android:textSize="15sp"
                    android:fontFamily="@font/biryani_regular"
                    android:textStyle="italic"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Alamat Pengiriman -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/background_checkout"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alamat Pengiriman"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:fontFamily="@font/biryani_bold"
                    android:layout_marginBottom="8dp" />

                <!-- Provinsi -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Provinsi"
                    android:textColor="@color/gray"
                    android:textSize="14sp"
                    android:layout_marginBottom="4dp" />

                <Spinner
                    android:id="@+id/spinnerProvinsi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/white"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp" />

                <!-- Kabupaten/Kota -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kabupaten / Kota"
                    android:textColor="@color/gray"
                    android:textSize="14sp"
                    android:layout_marginBottom="4dp" />

                <Spinner
                    android:id="@+id/spinnerKota"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/white"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp" />

                <!-- Kecamatan -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kecamatan"
                    android:textColor="@color/gray"
                    android:textSize="14sp"
                    android:layout_marginBottom="4dp" />

                <Spinner
                    android:id="@+id/spinnerKecamatan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/white"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp" />

                <!-- Kode Pos -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kode Pos"
                    android:textColor="@color/gray"
                    android:textSize="14sp"
                    android:layout_marginBottom="4dp" />

                <Spinner
                    android:id="@+id/spinnerKodePos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/white"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp" />

                <!-- Nama Jalan -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nama Jalan, Gedung, No. Rumah"
                    android:textColor="@color/gray"
                    android:textSize="14sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/edtJalan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Contoh: Jl. Merdeka No. 123"
                    android:inputType="textMultiLine"
                    android:minLines="2"
                    android:padding="14dp"
                    android:textColor="@color/black"
                    android:textColorHint="#888"
                    android:textSize="15sp"
                    android:background="@android:color/white"
                    android:gravity="top|start"
                    android:layout_marginBottom="8dp" />

                <!-- Detail Lainnya -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Detail Lainnya (Cth: Blok / Unit No., Patokan)"
                    android:textColor="@color/gray"
                    android:textSize="14sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/edtDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Contoh: Depan SPBU"
                    android:inputType="textMultiLine"
                    android:minLines="1"
                    android:padding="14dp"
                    android:textColor="@color/black"
                    android:textColorHint="#888"
                    android:textSize="15sp"
                    android:background="@android:color/white"
                    android:gravity="top|start"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btn_simpan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:text="Simpan Alamat"
                    android:textColor="@color/white"
                    android:background="@drawable/btn_bg_design"
                    android:textStyle="bold"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="8dp"
                    android:elevation="2dp" />
            </LinearLayout>

            <!-- Keranjang Pesanan -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/background_checkout"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Keranjang Pesanan"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:fontFamily="@font/biryani_bold"
                    android:layout_marginBottom="8dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_view_cart"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:background="@android:color/white"
                    android:clipToPadding="false"
                    android:scrollbars="vertical" />
            </LinearLayout>

            <!-- Metode Pembayaran -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/background_checkout"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Metode Pembayaran"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:fontFamily="@font/biryani_bold"
                    android:layout_marginBottom="12dp" />

                <RadioGroup
                    android:id="@+id/radioGroupPembayaran"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="8dp">

                    <!-- COD -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp"
                        android:onClick="onPaymentMethodClicked">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:contentDescription="COD" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="COD (Bayar di Tempat)"
                            android:textColor="@color/black"
                            android:textSize="15sp"
                            android:fontFamily="@font/biryani_regular" />

                        <RadioButton
                            android:id="@+id/rbCOD"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/brown"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>

                    <!-- BCA -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp"
                        android:onClick="onPaymentMethodClicked">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/logo_bca"
                            android:contentDescription="BCA" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="BCA Virtual Account"
                            android:textColor="@color/black"
                            android:textSize="15sp"
                            android:fontFamily="@font/biryani_regular" />

                        <RadioButton
                            android:id="@+id/rbBCA"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/brown"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>

                    <!-- Mandiri -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp"
                        android:onClick="onPaymentMethodClicked">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/logo_mandiri"
                            android:contentDescription="Mandiri" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="Mandiri Virtual Account"
                            android:textColor="@color/black"
                            android:textSize="15sp"
                            android:fontFamily="@font/biryani_regular" />

                        <RadioButton
                            android:id="@+id/rbMandiri"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/brown"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>

                    <!-- BRI -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp"
                        android:onClick="onPaymentMethodClicked">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/logo_briva"
                            android:contentDescription="BRI" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="BRI Virtual Account"
                            android:textColor="@color/black"
                            android:textSize="15sp"
                            android:fontFamily="@font/biryani_regular" />

                        <RadioButton
                            android:id="@+id/rbBRI"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/brown"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>

                    <!-- BNI -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp"
                        android:onClick="onPaymentMethodClicked">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/logo_bni"
                            android:contentDescription="BNI" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="BNI Virtual Account"
                            android:textColor="@color/black"
                            android:textSize="15sp"
                            android:fontFamily="@font/biryani_regular" />

                        <RadioButton
                            android:id="@+id/rbBNI"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/brown"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>
                </RadioGroup>
            </LinearLayout>

            <!-- Rincian Pesanan -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/background_checkout"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cek ringkasan belanjaanmu, yuk"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:fontFamily="@font/biryani_bold"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/txtLabelTotalHarga"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Total Harga (1 Barang)"
                        android:textColor="@color/gray"
                        android:textSize="16sp"
                        android:fontFamily="@font/biryani_regular" />

                    <TextView
                        android:id="@+id/txtTotalHargaBarang"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 0"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        android:fontFamily="@font/biryani_regular" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Total Ongkos Kirim"
                        android:textColor="@color/gray"
                        android:textSize="16sp"
                        android:fontFamily="@font/biryani_regular" />

                    <TextView
                        android:id="@+id/txtOngkir"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 0"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        android:fontFamily="@font/biryani_regular" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/black"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Total Tagihan"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:fontFamily="@font/biryani_bold" />

                    <TextView
                        android:id="@+id/txtTotalTagihan_Ringkasan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 0"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:fontFamily="@font/biryani_bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- total_container (Tetap di bawah) -->
    <LinearLayout
        android:id="@+id/total_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@color/white"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/layout_total_tagihan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Total Tagihan"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:fontFamily="@font/biryani_bold" />

            <TextView
                android:id="@+id/txtTotalTagihan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 0"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:fontFamily="@font/biryani_bold" />
        </LinearLayout>

        <Button
            android:id="@+id/btnBuatPesanan"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Buat Pesanan"
            android:background="@drawable/btn_bg_design"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:elevation="4dp" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>