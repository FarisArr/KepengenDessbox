<?xml version="1.0" encoding="utf-8"?>
<!-- activity_detail_pesanan.xml berhasil -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E9E9E9">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Tombol Back -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Kembali"
            android:layout_marginStart="8dp"
            android:layout_gravity="start|center_vertical" />

        <!-- TextView di tengah Toolbar -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Detail Pesanan"
            android:textColor="@color/brown"
            android:textSize="24sp"
            android:fontFamily="@font/biryani_extrabold"
            android:layout_gravity="center" />
    </androidx.appcompat.widget.Toolbar>

    <!-- ScrollView untuk scrolling konten -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@+id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/background_detail_pesanan"
            android:padding="16dp">

            <!-- Informasi Pemesan -->
            <LinearLayout
                android:id="@+id/llInfoPemesan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/background_card"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Informasi Pemesan"
                    android:textSize="16sp"
                    android:textColor="@color/black"
                    android:fontFamily="@font/biryani_extrabold"
                    android:layout_marginBottom="12dp" />

                <!-- Nama Pemesan -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Nama"
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/biryani_regular" />
                    <TextView
                        android:id="@+id/txtNamaPemesan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Udin Comal"
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/biryani_regular" />
                </LinearLayout>

                <!-- 🔹 Nomor Telepon -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Nomor Telepon"
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/biryani_regular" />
                    <TextView
                        android:id="@+id/txtNomorTelepon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/biryani_regular" />
                </LinearLayout>

                <!-- Nomor Pesanan -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Nomor Pesanan"
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/biryani_regular" />
                    <TextView
                        android:id="@+id/txtNomorPesanan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="213438249389"
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/biryani_regular" />
                </LinearLayout>

                <!-- Waktu Pemesanan -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Waktu Pemesanan"
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/biryani_regular" />
                    <TextView
                        android:id="@+id/txtWaktuPesanan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="18 Des 2021 | 08:00"
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/biryani_regular" />
                </LinearLayout>

                <!-- Metode Pembayaran -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Metode Pembayaran"
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/biryani_regular" />
                    <TextView
                        android:id="@+id/txtMetodePembayaran"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="COD (Bayar di Tempat)"
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/biryani_regular" />
                </LinearLayout>

                <!-- Alamat Pengiriman -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Alamat Pengiriman"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:fontFamily="@font/biryani_regular" />

                <TextView
                    android:id="@+id/txtAlamatPengiriman"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:fontFamily="@font/biryani_regular"
                    android:layout_marginBottom="8dp" />
            </LinearLayout>

            <!-- 🔹 Status Pesanan (Ditambahkan di tengah) -->
            <LinearLayout
                android:id="@+id/llStatusPesanan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/background_card"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@+id/llInfoPemesan"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status Pesanan"
                    android:textSize="16sp"
                    android:textColor="@color/black"
                    android:fontFamily="@font/biryani_extrabold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/txtStatusPesanan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Belum diproses"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:fontFamily="@font/biryani_bold" />

                <TextView
                    android:id="@+id/txtBatasWaktu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bayar dalam: 14 menit 30 detik"
                    android:textSize="14sp"
                    android:textColor="@color/red"
                    android:fontFamily="@font/biryani_bold"
                    android:layout_marginTop="4dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Daftar Pesanan -->
            <LinearLayout
                android:id="@+id/llDaftarPesanan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/background_card"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@+id/llStatusPesanan"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daftar Pesanan"
                    android:textSize="16sp"
                    android:textColor="@color/black"
                    android:fontFamily="@font/biryani_extrabold"
                    android:layout_marginBottom="12dp" />

                <!-- Container untuk daftar item pesanan -->
                <LinearLayout
                    android:id="@+id/linear_pesanan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <!-- Item pesanan akan ditambahkan di sini secara dinamis -->
                </LinearLayout>

                <!-- Ongkir -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Ongkos Pengiriman"
                        android:textSize="16sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/biryani_bold"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/txtHargaOngkir"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"
                        android:text="Rp 5.000"
                        android:textSize="16sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/biryani_bold" />
                </LinearLayout>

                <!-- Garis Pemisah -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/gray"
                    android:layout_marginVertical="8dp" />

                <!-- Total -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="TOTAL"
                        android:textSize="16sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/biryani_bold"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/txtTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 33.000"
                        android:textSize="16sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/biryani_bold"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- 🔹 Tombol untuk USER -->
            <LinearLayout
                android:id="@+id/linearBtnUser"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@+id/llDaftarPesanan"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Baris 1: Lanjutkan Pembayaran + Konfirmasi Pesanan -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnLanjutkanPembayaran"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="Lanjutkan Pembayaran"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:background="@drawable/btn_bg_design"
                        android:backgroundTint="@color/brown" />

                    <Button
                        android:id="@+id/btnKonfirmasiPesanan"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="Konfirmasi Pesanan"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:background="@drawable/btn_bg_design"
                        android:backgroundTint="@color/brown" />
                </LinearLayout>

                <!-- Baris 2: Pesan Lagi + Batalkan Pesanan -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <Button
                        android:id="@+id/btnPesanLagi"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="Pesan Lagi"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:background="@drawable/btn_bg_design"
                        android:backgroundTint="@color/green"
                        android:visibility="gone" />

                    <Button
                        android:id="@+id/btnBatalkanPesanan"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="Batalkan Pesanan"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:background="@drawable/btn_bg_design"
                        android:backgroundTint="@color/red" />
                </LinearLayout>
            </LinearLayout>

            <!-- 🔹 Tombol untuk ADMIN -->
            <LinearLayout
                android:id="@+id/linearBtnAdmin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@+id/llDaftarPesanan"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Baris 1: Diproses + Dikirim -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnDiproses"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="Diproses"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:background="@drawable/btn_bg_design"
                        android:backgroundTint="@color/brown" />

                    <Button
                        android:id="@+id/btnDikirim"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="Dikirim"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:background="@drawable/btn_bg_design"
                        android:backgroundTint="@color/brown" />
                </LinearLayout>

                <!-- Baris 2: Selesai + Dibatalkan -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <Button
                        android:id="@+id/btnSelesai"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="Selesai"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:background="@drawable/btn_bg_design"
                        android:backgroundTint="@color/green" />

                    <Button
                        android:id="@+id/btnDibatalkan"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="Dibatalkan"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:background="@drawable/btn_bg_design"
                        android:backgroundTint="@color/red" />
                </LinearLayout>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>