<?xml version="1.0" encoding="utf-8"?>
<!--activity_admin.xml berhasil-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin"
            android:layout_gravity="center"
            android:textSize="24sp"
            android:textColor="@color/brown"
            android:fontFamily="@font/biryani_extrabold" />
    </androidx.appcompat.widget.Toolbar>

    <!-- Selamat Datang -->
    <TextView
        android:id="@+id/txtSelamatDatang"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:text="Selamat datang, Admin"
        android:textSize="18sp"
        android:textColor="@color/black"
        android:fontFamily="@font/biryani_bold"
        app:layout_constraintTop_toBottomOf="@+id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Tombol Kelola Menu -->
    <Button
        android:id="@+id/btnKelolaMenu"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="20dp"
        android:text="Kelola Menu"
        android:textSize="18sp"
        android:textStyle="bold"
        android:background="@drawable/btn_bg_design"
        android:textColor="@color/white"
        android:drawablePadding="8dp"
        app:layout_constraintTop_toBottomOf="@+id/txtSelamatDatang"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Tombol Riwayat Pesanan -->
    <Button
        android:id="@+id/btnRiwayatPesanan"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="20dp"
        android:text="Lihat Riwayat Pesanan"
        android:textSize="18sp"
        android:textStyle="bold"
        android:background="@drawable/btn_bg_design"
        android:textColor="@color/white"
        android:drawablePadding="8dp"
        app:layout_constraintTop_toBottomOf="@+id/btnKelolaMenu"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Tombol Lihat Ulasan -->
    <Button
        android:id="@+id/btnLihatUlasan"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        android:text="Lihat Ulasan"
        android:textSize="18sp"
        android:textStyle="bold"
        android:background="@drawable/btn_bg_design"
        android:textColor="@color/white"
        android:drawablePadding="8dp"
        app:layout_constraintTop_toBottomOf="@+id/btnRiwayatPesanan"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Tombol Laporan Penjualan -->
    <Button
        android:id="@+id/btnLaporanPenjualan"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="20dp"
        android:text="Laporan Penjualan"
        android:textSize="18sp"
        android:textStyle="bold"
        android:background="@drawable/btn_bg_design"
        android:textColor="@color/white"
        android:drawablePadding="8dp"
        app:layout_constraintTop_toBottomOf="@+id/btnLihatUlasan"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Tombol Logout -->
    <Button
        android:id="@+id/btnLogoutAdmin"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="40dp"
        android:text="Logout Admin"
        android:textSize="18sp"
        android:textStyle="bold"
        android:background="@drawable/btn_bg_design"
        android:textColor="@color/white"
        android:backgroundTint="#FF0000"
        android:drawablePadding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>