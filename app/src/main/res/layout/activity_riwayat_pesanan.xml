<?xml version="1.0" encoding="utf-8"?>
<!--activity_riwayat_pesanan.xml berhasil-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_riwayat_pesanan"
    tools:context=".RiwayatPesananActivity">

    <!-- Toolbar dengan judul di tengah -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Riwayat Pesanan"
            android:textSize="24sp"
            android:textColor="@color/brown"
            android:fontFamily="@font/biryani_extrabold"
            android:layout_gravity="center" />

    </androidx.appcompat.widget.Toolbar>

    <!-- RecyclerView untuk daftar riwayat -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view_riwayat_pesanan"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@+id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>